# ~/.config/dotfiles/local.env — machine-local settings
# Created by bootstrap.sh from local.env.template. Edit freely.
# This file is NOT tracked in git — each machine keeps its own copy.

# Root directory where your git repositories live on this machine.
# Used by claude-agent-pick (prefix A) to offer a repo picker when
# you're not already inside a git repo.
REPOS_DIR="$HOME/Github"

# Root directory where claude-agent (prefix A) places git worktrees.
# Each repo gets a subdirectory: $WORKTREES_DIR/<repo>/<label>/
WORKTREES_DIR="$HOME/Worktrees"
