#!/usr/bin/env bash
# claude-agent-rename <new-label>
#
# Atomically promote a placeholder worktree to a real ticket label. Renames
# the branch, moves the worktree directory, renames the matching tmux
# window, and updates every pane's shell cwd — all WITHOUT exiting Claude.
#
# How it survives a running Claude session:
#
#   `git worktree move` is a POSIX directory rename — the inode survives,
#   so any process with the dir as its cwd (including Claude and its child
#   shells) keeps working via the kernel's inode handle. Absolute-path file
#   ops continue to resolve to the new location. The only stale piece is
#   each shell's recorded `$PWD` string; we mend that by sending
#   `cd <new-path>` to every pane that was inside the old worktree.
#
# If the worktree-move fails (foreign filesystem, permission, target exists),
# the script unwinds the branch rename so you don't end up in a half-state.

set -euo pipefail

new_label="${1:-}"
if [ -z "$new_label" ]; then
  echo "usage: claude-agent-rename <new-label>" >&2
  exit 1
fi

# Validate label shape: lowercase alphanumeric + hyphens, must start
# alphanumeric. Rejects slashes/spaces/leading-hyphen.
if [[ ! "$new_label" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
  echo "claude-agent-rename: label must be lowercase alphanumeric + hyphens" >&2
  echo "  example: rec-380-slice-1-pino-sentry-transport" >&2
  exit 1
fi

cwd="${PWD}"
worktree=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null) || {
  echo "claude-agent-rename: not inside a git repo (cwd=$cwd)" >&2
  exit 1
}

old_branch=$(git -C "$worktree" rev-parse --abbrev-ref HEAD)
main_root=$(git -C "$worktree" worktree list --porcelain | awk '/^worktree/ { print $2; exit }')
repo=$(basename "$main_root")

# Refuse to rename the main checkout — that would break every other worktree's
# .git pointer and isn't the intent.
if [ "$worktree" = "$main_root" ]; then
  echo "claude-agent-rename: refusing to rename main checkout ($main_root)" >&2
  echo "  This script is for claude-agent placeholder worktrees." >&2
  exit 1
fi

# Idempotency — already there
if [ "$old_branch" = "$new_label" ]; then
  echo "Already on branch '$new_label' — nothing to do"
  exit 0
fi

# Branch collision
if git -C "$worktree" show-ref --verify --quiet "refs/heads/$new_label"; then
  echo "claude-agent-rename: branch '$new_label' already exists locally" >&2
  echo "  Pick a different label, or delete: git -C $worktree branch -D $new_label" >&2
  exit 1
fi

old_dirname=$(basename "$worktree")
worktree_parent=$(dirname "$worktree")
new_worktree="$worktree_parent/$new_label"

# Directory collision (separate from branch collision because the names
# could go out of sync via manual operations).
if [ -e "$new_worktree" ]; then
  echo "claude-agent-rename: target directory already exists: $new_worktree" >&2
  echo "  Remove it first, or pick a different label." >&2
  exit 1
fi

# --- Rename branch ----------------------------------------------------------
git -C "$worktree" branch -m "$old_branch" "$new_label"
echo "✓ branch: $old_branch → $new_label"

# --- Move worktree directory -----------------------------------------------
# `git worktree move` refuses to move the cwd worktree, so we invoke it
# from the main checkout. Unwind the branch rename on failure so we don't
# leave a half-renamed state.
if ! (cd "$main_root" && git worktree move "$worktree" "$new_worktree" 2>/dev/null); then
  echo "claude-agent-rename: worktree move failed — unwinding branch rename" >&2
  git -C "$worktree" branch -m "$new_label" "$old_branch" 2>/dev/null || true
  exit 1
fi
echo "✓ worktree: $worktree → $new_worktree"

# --- Migrate Claude Code workspace trust to the new path -------------------
# Claude Code keys workspace trust by absolute path in ~/.claude.json
# (.projects.<path>.hasTrustDialogAccepted). The worktree move would orphan
# the old path's entry, so the renamed worktree silently loses project
# skills + hooks. Copy the entry forward — and delete the stale old one to
# keep the registry from accumulating dead paths over many promotions.
migrate_trust() {
  local old_path="$1" new_path="$2"
  local config="$HOME/.claude.json"
  [ -f "$config" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  local tmp
  tmp=$(mktemp -t claude-trust.XXXXXX) || return 0
  if jq --arg old "$old_path" --arg new "$new_path" '
    if .projects[$old] then
      .projects[$new] = .projects[$old] | del(.projects[$old])
    else
      .projects[$new] //= { hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true }
    end
  ' "$config" > "$tmp" 2>/dev/null; then
    mv "$tmp" "$config"
    echo "✓ trust: $old_path → $new_path"
  else
    rm -f "$tmp"
  fi
}
migrate_trust "$worktree" "$new_worktree"

# --- Update shell cwds in matching panes -----------------------------------
# Any pane (across any session) whose cwd starts with the old worktree path
# needs `cd <new-path>` so its $PWD stops lying. The kernel handle is still
# valid via inode, but the shell's recorded path is stale until the next cd.
if [ -n "${TMUX:-}" ]; then
  tmux list-panes -aF '#{pane_id} #{pane_current_path}' 2>/dev/null \
    | while read -r pane_id pane_path; do
      if [[ "$pane_path" == "$worktree"* ]]; then
        new_path="${pane_path/$worktree/$new_worktree}"
        # `cd && clear` rebinds $PWD; the clear keeps the rebind line from
        # cluttering Claude's transcript if the pane happens to be running it.
        tmux send-keys -t "$pane_id" "cd '$new_path' && clear" Enter 2>/dev/null || true
      fi
    done

  # --- Rename tmux window (same shortening rule as claude-agent) ----------
  window_label=$(printf '%s' "$new_label" | sed -E 's/^(rec|REC)-/r/' | cut -c1-24)
  # Find the window that hosts our worktree. The convention is that
  # claude-agent named the window after the old label, but we look it up by
  # pane path so a manually-renamed window still gets caught.
  matching_window=$(tmux list-windows -aF '#{session_name}:#{window_index} #{pane_current_path}' 2>/dev/null \
    | awk -v root="$new_worktree" '$2 ~ ("^" root) { print $1; exit }')
  if [ -n "$matching_window" ]; then
    tmux rename-window -t "$matching_window" "$window_label" 2>/dev/null || true
    echo "✓ tmux window → $window_label"
  fi

  tmux display-message -d 3000 "promoted → $new_label" 2>/dev/null || true
fi
